# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Local MongoDB (default — works out of the box if MongoDB is installed)
MONGO_URI=mongodb://localhost:27017/raitha_mitra

# MongoDB Atlas (use this for cloud/production):
# MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASS@cluster0.xxxxx.mongodb.net/raitha_mitra?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────────────────────────
# IMPORTANT: change this to a long random string in production!
# Must be the SAME string in all server files.
JWT_SECRET=raitha_mitra_dev_secret_key_12345
JWT_EXPIRE=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ─── File Upload ──────────────────────────────────────────────────────────────
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# ─── PhonePe Payment (leave as-is for mock/demo mode) ─────────────────────────
PHONEPE_MERCHANT_ID=RAITHAMITRAPAY
PHONEPE_SALT_KEY=mock_salt_key_for_demo
PHONEPE_SALT_INDEX=1

# ─── Twilio WhatsApp (optional) ───────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
